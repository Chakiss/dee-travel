// TARGET Firestore rules — DRAFT, NOT DEPLOYED.
// Role-based via custom claims. Deploy only after: (a) editor accounts have the
// custom claim set, (b) impact reviewed & approved. See firebase/README.md.
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function role() { return isSignedIn() ? request.auth.token.role : null; }
    function isEditor() { return role() == 'editor' || role() == 'admin'; }
    function isAdmin() { return role() == 'admin'; }
    function isPublished() { return resource.data.status == 'published'; }

    // Public content: world-readable ONLY when published; editors read/write all.
    match /places/{id}       { allow read: if isPublished() || isEditor(); allow write: if isEditor(); }
    match /articles/{id}     { allow read: if isPublished() || isEditor(); allow write: if isEditor(); }
    match /events/{id}       { allow read: if isPublished() || isEditor(); allow write: if isEditor(); }

    // Reference data: public read, editor write.
    match /categories/{id}   { allow read: if true; allow write: if isEditor(); }
    match /geographies/{id}  { allow read: if true; allow write: if isEditor(); }
    match /provinces/{id}    { allow read: if true; allow write: if isEditor(); }
    match /districts/{id}    { allow read: if true; allow write: if isEditor(); }
    match /subdistricts/{id} { allow read: if true; allow write: if isEditor(); }

    // Marketing: internal only — no public read.
    match /marketingAssets/{id}   { allow read, write: if isEditor(); }
    match /contentCalendar/{id}   { allow read, write: if isEditor(); }

    // Users: self-read; only admins manage.
    match /users/{uid} {
      allow read: if isAdmin() || request.auth.uid == uid;
      allow write: if isAdmin();
    }

    // Deny everything not matched above.
    match /{document=**} { allow read, write: if false; }
  }
}
