# Copy to apps/web/.env and apps/admin/.env (or a root .env) and fill in.
# The Firebase WEB config is public-by-design (safe on the client). It is NOT a secret.
# Real secrets (service-account JSON) never go here — see .gitignore.

# --- Firebase web config (production project: deetravel-project) ---
NUXT_PUBLIC_FIREBASE_API_KEY=
NUXT_PUBLIC_FIREBASE_AUTH_DOMAIN=deetravel-project.firebaseapp.com
NUXT_PUBLIC_FIREBASE_PROJECT_ID=deetravel-project
NUXT_PUBLIC_FIREBASE_STORAGE_BUCKET=deetravel-project.appspot.com
NUXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=952800947165
NUXT_PUBLIC_FIREBASE_APP_ID=

# --- Local development ---
# When "true", the app connects to the local Emulator Suite instead of the cloud.
NUXT_PUBLIC_USE_EMULATOR=true
